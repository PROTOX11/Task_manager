# Optional: where Express runs (used by next.config.mjs rewrites only — not sent to the browser)
BACKEND_URL=http://localhost:5000

# Optional: call API directly (skips proxy). Must be Express URL, NOT the Next.js port.
# Leave unset to use same-origin /api → proxied to BACKEND_URL
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
