# Express API (must match backend/.env PORT=5000). Used by next.config.mjs to proxy /api/*
BACKEND_URL=http://localhost:5000

# Do NOT set NEXT_PUBLIC_API_BASE_URL to http://localhost:3000 — that is Next.js, not Express.
# Omit NEXT_PUBLIC_API_BASE_URL to use same-origin /api (recommended with proxy).
